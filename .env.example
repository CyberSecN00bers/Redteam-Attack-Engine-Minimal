# CyberRange DAST Agent — Environment Configuration
# Copy this file to .env and fill in your values.

# Google Gemini API key (required for LLM analysis node)
GEMINI_API_KEY=

# Gemini model name (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Runtime target configuration (used by Docker/Docker Compose)
TARGET_URL=http://127.0.0.1:80
HOST_HEADER=vulnerable.cyberrange.local
ATTACK_PROFILE=stealth

# Qdrant vector DB for payload retrieval (optional — falls back to built-in payloads)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=payloads
